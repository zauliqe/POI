rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Conversaciones y mensajes
    match /conversaciones/{conversationId} {
      allow read: if request.auth.uid != null;
      allow create, update: if request.auth.uid != null;
      
      match /mensajes/{messageId} {
        allow read: if request.auth.uid != null;
        allow create: if request.auth.uid != null;
      }
    }
    
    // Usuarios
    match /usuarios/{userId} {
      allow read: if request.auth.uid != null;
      allow create, update: if request.auth.uid == userId;
    }
    
    // Grupos
    match /grupos/{groupId} {
      allow read: if request.auth.uid != null && resource.data.miembros.hasAny([request.auth.uid]);
      allow create: if request.auth.uid != null;
      allow update: if request.auth.uid != null && resource.data.miembros.hasAny([request.auth.uid]);
    }
    
    // VIDEOLLAMADAS - Nueva estructura con attempts/subcollection
    match /llamadas/{conversationId} {
      // Permite crear la conversación de llamadas
      allow create: if request.auth.uid != null;
      allow read: if request.auth.uid != null;
      
      // Cada intento de llamada
      match /attempts/{attemptId} {
        // Caller puede crear y modificar
        allow create: if request.auth.uid != null && request.resource.data.caller == request.auth.uid;
        
        // Caller y Callee pueden leer
        allow read: if request.auth.uid != null && 
          (request.auth.uid == resource.data.caller || 
           request.auth.uid == resource.data.callee);
        
        // Caller y Callee pueden actualizar
        allow update: if request.auth.uid != null && 
          (request.auth.uid == resource.data.caller || 
           request.auth.uid == resource.data.callee);
      }
    }
  }
}
